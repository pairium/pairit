{
  "schema_version": "0.1.0",
  "initialPageId": "consent",
  "pages": {
    "consent": {
      "id": "consent",
      "components": [
        {
          "type": "text",
          "props": {
            "text": "# Team Decision Study\n\nYou will be paired with another participant to make a decision together.\n"
          },
          "id": "text-0"
        },
        {
          "type": "buttons",
          "props": {
            "buttons": [
              {
                "id": "agree",
                "text": "I agree to participate",
                "action": {
                  "type": "go_to",
                  "target": "matching"
                }
              }
            ]
          },
          "id": "buttons-1"
        }
      ]
    },
    "matching": {
      "id": "matching",
      "components": [
        {
          "type": "matchmaking",
          "props": {
            "poolId": "main_pool",
            "num_users": 2,
            "timeoutSeconds": 180,
            "timeoutTarget": "matching_timeout"
          },
          "id": "matchmaking-0"
        },
        {
          "type": "buttons",
          "props": {
            "buttons": [
              {
                "id": "matched",
                "text": "Continue to chat",
                "action": {
                  "type": "go_to",
                  "target": "chat"
                }
              }
            ]
          },
          "id": "buttons-1"
        }
      ]
    },
    "matching_timeout": {
      "id": "matching_timeout",
      "end": true,
      "components": [
        {
          "type": "text",
          "props": {
            "text": "We couldn't find enough group members at this time. Thank you for trying!"
          },
          "id": "text-0"
        }
      ]
    },
    "chat": {
      "id": "chat",
      "components": [
        {
          "type": "text",
          "props": {
            "text": "**Your task:** Decide together which candidate to hire from the three profiles below."
          },
          "id": "text-0"
        },
        {
          "type": "chat",
          "id": "chat-1"
        },
        {
          "type": "buttons",
          "props": {
            "buttons": [
              {
                "id": "done",
                "text": "We've decided",
                "action": {
                  "type": "go_to",
                  "target": "thanks"
                }
              }
            ]
          },
          "id": "buttons-2"
        }
      ]
    },
    "thanks": {
      "id": "thanks",
      "end": true,
      "components": [
        {
          "type": "text",
          "props": {
            "text": "Thank you for participating!"
          },
          "id": "text-0"
        }
      ]
    }
  },
  "matchmaking": [
    {
      "id": "main_pool",
      "num_users": 2,
      "timeoutSeconds": 180,
      "timeoutTarget": "matching_timeout"
    }
  ]
}