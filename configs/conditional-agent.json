{
  "schema_version": "0.1.0",
  "initialPageId": "pick",
  "pages": {
    "pick": {
      "id": "pick",
      "components": [
        {
          "type": "text",
          "props": {
            "text": "# Conditional Agent Demo\n\nPick your favorite dish, then chat with the chef.\n"
          },
          "id": "text-0"
        },
        {
          "type": "survey",
          "props": {
            "items": [
              {
                "id": "dish",
                "text": "What's your favorite dish?",
                "answer": {
                  "multiple_choice": {
                    "choices": [
                      "Pizza",
                      "Sushi",
                      "Tacos"
                    ]
                  }
                }
              }
            ]
          },
          "id": "survey-1"
        },
        {
          "type": "buttons",
          "props": {
            "buttons": [
              {
                "id": "go",
                "text": "Chat with the chef",
                "action": {
                  "type": "go_to",
                  "target": "chat"
                }
              }
            ]
          },
          "id": "buttons-2"
        }
      ]
    },
    "chat": {
      "id": "chat",
      "components": [
        {
          "type": "chat",
          "props": {
            "agents": [
              "chef"
            ]
          },
          "id": "chat-0"
        },
        {
          "type": "buttons",
          "props": {
            "buttons": [
              {
                "id": "done",
                "text": "Done",
                "action": {
                  "type": "go_to",
                  "target": "thanks"
                }
              }
            ]
          },
          "id": "buttons-1"
        }
      ]
    },
    "thanks": {
      "id": "thanks",
      "end": true,
      "components": [
        {
          "type": "text",
          "props": {
            "text": "Thanks! You picked **{{user_state.dish}}**."
          },
          "id": "text-0"
        }
      ]
    }
  },
  "agents": [
    {
      "id": "chef",
      "model": "gpt-4o-mini",
      "trigger": "on_join",
      "system": "You are a chef.",
      "prompts": [
        {
          "when": "user_state.dish == 'Pizza'",
          "system": "You are an enthusiastic Italian chef. The participant just told you\nthey love pizza. Greet them by raving about pizza — mention your\nfavorite toppings, dough technique, etc. Keep it to 2-3 sentences.\nAlways talk about pizza in every response.\n"
        },
        {
          "when": "user_state.dish == 'Sushi'",
          "system": "You are a Japanese sushi master. The participant just told you\nthey love sushi. Greet them by sharing your passion for sushi —\nmention fresh fish, rice preparation, etc. Keep it to 2-3 sentences.\nAlways talk about sushi in every response.\n"
        },
        {
          "when": "user_state.dish == 'Tacos'",
          "system": "You are a Mexican street food chef. The participant just told you\nthey love tacos. Greet them by celebrating tacos — mention salsas,\ntortillas, fillings, etc. Keep it to 2-3 sentences.\nAlways talk about tacos in every response.\n"
        },
        {
          "system": "You are a friendly chef. Greet the participant and ask what\nkind of food they enjoy. Keep it to 2-3 sentences.\n"
        }
      ]
    }
  ]
}